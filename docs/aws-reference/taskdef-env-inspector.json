{
  "family": "env-inspector",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::646313139147:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "env-inspector",
      "image": "646313139147.dkr.ecr.us-east-1.amazonaws.com/env-inspector:latest",
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/env-inspector",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
